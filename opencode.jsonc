{
  "$schema": "https://opencode.ai/config.json",

  // Pair this with custom agent markdown files installed in
  // ~/.config/opencode/agents/ (or another supported OpenCode agent directory).
  // Keep this companion config minimal: pick the default primary agent and
  // apply only the permissions the current config contract can express cleanly.
  "default_agent": "orchestrator",

  "agent": {
    "scout": {
      "permission": {
        // Later rules win. This keeps scout read-oriented while still allowing
        // optional notes under .opencode/journal/.
        "edit": {
          "*": "deny",
          ".opencode/journal/**": "allow"
        }
      }
    },
    "reviewer": {
      "permission": {
        "edit": {
          "*": "deny",
          ".opencode/journal/**": "allow"
        }
      }
    }
  }

  // This minimal config does not make bash truly read-only. Shell side effects
  // still depend on agent instructions and any interactive permission checks.
}
