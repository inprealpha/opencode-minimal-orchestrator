{
  "$schema": "https://opencode.ai/config.json",

  // Pair this with custom agent markdown files installed in
  // ~/.config/opencode/agents/ (or another supported OpenCode agent directory).
  // Keep this companion config minimal: pick the default primary agent and
  // apply only the permissions the current config contract can express cleanly.
  "default_agent": "orchestrator",

  "agent": {
    "scout": {
      "permission": {
        // Later rules win. This keeps scout read-oriented while still allowing
        // optional notes under .opencode/journal/.
        "edit": {
          "*": "deny",
          ".opencode/journal/**": "allow"
        }
      }
    },
    "reviewer": {
      "permission": {
        "edit": {
          "*": "deny",
          ".opencode/journal/**": "allow"
        }
      }
    }
  }

  // ── Runtime Plugin ──────────────────────────────────────────────
  // The orchestrator-runtime plugin is auto-discovered from
  // .opencode/plugin/orchestrator-runtime.ts when installed there.
  //
  // If you prefer explicit loading (e.g. from a non-standard path),
  // uncomment the line below and adjust the path:
  //
  // "plugin": ["file://.opencode/plugin/orchestrator-runtime.ts"]
  //
  // The plugin adds:
  //   - Shell command guard for read-only agents (scout, reviewer)
  //   - Write guard enforcing journal-only writes for read-only agents
  //   - Compaction recovery context injection
  //   - Delegated task tracking with poll_tasks custom tool
  //   - Error classification annotations on tool output
  //   - Completed-task notifications injected into chat messages
  //
  // Shell discipline and edit permissions that were previously
  // prompt-only are now also enforced by plugin hooks.
  // To disable: remove the plugin file or set "plugin": [].
}
